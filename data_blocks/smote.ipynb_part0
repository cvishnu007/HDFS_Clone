  {
   "cell_type": "markdown",
   "id": "f6c7ffea",
   "metadata": {},
   "source": [
    "# Smote Without Multiplier"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 60,
   "id": "1949e9b1",
   "metadata": {},
   "outputs": [],
   "source": [
    "feature_cols = [c for c in df.columns if c != 'Class']\n",
    "\n",
    "# 2. Combine all features into a single DenseVector column called 'features'\n",
    "assembler = VectorAssembler(inputCols=feature_cols, outputCol=\"features\")\n",
    "df_vec = assembler.transform(df)\n",
    "\n",
    "# 3. Add a unique ID to every row (crucial for joining later)\n",
    "df_vec = df_vec.withColumn(\"id\", monotonically_increasing_id())\n",
    "\n",
    "# 4. Split the dataset into majority (normal) and minority (fraud)\n",
    "majority_df = df_vec.filter(col(\"Class\") == 0)\n",
    "minority_df = df_vec.filter(col(\"Class\") == 1)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 61,
   "id": "1ce1240e",
   "metadata": {},
   "outputs": [],
   "source": [
    "brp = BucketedRandomProjectionLSH(\n",
    "    inputCol=\"features\", \n",
    "    outputCol=\"hashes\", \n",
    "    bucketLength=2.0, \n",
    "    numHashTables=3\n",
    ")\n",
    "\n",
    "# Fit the LSH model strictly on the minority data\n",
    "lsh_model = brp.fit(minority_df)\n",
    "\n",
    "# 2. Perform an Approximate Similarity Join\n",
    "# This joins the minority dataframe to itself based on feature similarity\n",
    "neighbors = lsh_model.approxSimilarityJoin(\n",
    "    minority_df, \n",
    "    minority_df, \n",
    "    threshold=float('inf'), \n",
    "    distCol=\"EuclideanDistance\"\n",
    ")\n",
    "\n",
    "# 3. Clean up the join results\n",
    "# Remove self-matches (a point is its own closest neighbor)\n",
    "neighbors = neighbors.filter(col(\"datasetA.id\") != col(\"datasetB.id\"))\n",
    "\n",
    "# 4. Keep only the top k neighbors (let's use k=5)\n",
    "windowSpec = Window.partitionBy(\"datasetA.id\").orderBy(\"EuclideanDistance\")\n",
    "top_k_neighbors = neighbors.withColumn(\"rank\", row_number().over(windowSpec)) \\\n",
    "                           .filter(col(\"rank\") <= 5)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 62,
   "id": "08c7b752",
   "metadata": {},
   "outputs": [],
   "source": [
    "def generate_synthetic_point(base_vector, neighbor_vector):\n",
    "    base_arr = base_vector.toArray()\n",
    "    neighbor_arr = neighbor_vector.toArray()\n",
    "    \n",
    "    # Calculate the difference and apply a random multiplier\n",
    "    difference = neighbor_arr - base_arr\n",
    "    random_step = random.uniform(0, 1)\n",
    "    \n",
    "    synthetic_arr = base_arr + (random_step * difference)\n",
    "    return Vectors.dense(synthetic_arr)\n",
    "\n",
    "# 2. Register it as a Spark UDF that returns a Vector\n",
    "smote_udf = udf(generate_synthetic_point, VectorUDT())\n",
    "\n",
    "# 3. Apply the UDF to create the new synthetic feature vectors\n",
    "synthetic_data = top_k_neighbors.withColumn(\n",
    "    \"synthetic_features\", \n",
    "    smote_udf(col(\"datasetA.features\"), col(\"datasetB.features\"))\n",
    ")\n",
    "\n",
    "# 4. Format the synthetic dataframe to match the original schema\n",
    "synthetic_df = synthetic_data.select(\n",
    "    col(\"synthetic_features\").alias(\"features\")\n",
    ").withColumn(\"Class\", lit(1))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 63,
   "id": "6fe27491",
   "metadata": {},
   "outputs": [
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "[Stage 522:======================================>                  (6 + 3) / 9]\r"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "+-----+------+\n",
      "|Class| count|\n",
      "+-----+------+\n",
      "|    0|284315|\n",
      "|    1|  1625|\n",
      "+-----+------+\n",
      "\n"
     ]
    },
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "                                                                                \r"
     ]
    }
   ],
   "source": [
    "# 1. Standardize the original dataframes to match the synthetic one\n",
    "minority_clean = minority_df.select(\"features\", \"Class\")\n",
    "majority_clean = majority_df.select(\"features\", \"Class\")\n",
    "\n",
    "# 2. Union everything together\n",
    "final_smoted_df = majority_clean.union(minority_clean).union(synthetic_df)\n",
    "\n",
    "# 3. Check the new class distribution\n",
    "\n",
    "final_smoted_df.groupBy(\"Class\").count().show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 64,
   "id": "3401caeb",
   "metadata": {},
   "outputs": [],
   "source": [
    "def convert_to_csv(name,opname):\n",
    "    final_smoted_df_array = name.withColumn(\"features_array\",vector_to_array(\"features\"))\n",
    "    original_col = [\"Time\"] + [f\"V{i}\" for i in range(1,29)] + [\"Amount\"]\n",
    "    for i,col_name in enumerate(original_col):\n",
    "        final_smoted_df_array = final_smoted_df_array.withColumn(col_name,col(\"features_array\")[i])\n",
    "    final_smoted_df_array = final_smoted_df_array.drop(\"features\",\"features_array\")\n",
    "    final_smoted_df_array.coalesce(1).write.csv(f\"{opname}.csv\")\n",
    "    print(\"CSV saved\")\n",
    "    return final_smoted_df_array\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 65,
   "id": "6c74791e",
   "metadata": {},
   "outputs": [
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "[Stage 540:>                                                        (0 + 1) / 1]\r"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "CSV saved\n"
     ]
    },
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "                                                                                \r"
     ]
    }
   ],
   "source": [
    "smote_wo_multiplier = convert_to_csv(final_smoted_df,\"smote-without-multiplier\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 66,
   "id": "333325d9",
   "metadata": {},
   "outputs": [
    {
     "name": "stderr",
