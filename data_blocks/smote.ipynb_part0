     "text": [
      "                                                                                \r"
     ]
    }
   ],
   "source": [
    "smote_wo_multiplier.groupBy(\"Class\").count().show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "43a0b2e5",
   "metadata": {},
   "source": [
    "# SMOTE WITH MULTIPLIER"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 67,
   "id": "c6cea5e4",
   "metadata": {},
   "outputs": [
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "                                                                                \r"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Finding approximate k-nearest neighbors via LSH...\n",
      "Generating roughly 283823 synthetic points...\n",
      "Final Balanced Dataset Distribution:\n"
     ]
    },
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "[Stage 582:==================================================>      (8 + 1) / 9]\r"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "+-----+------+\n",
      "|Class| count|\n",
      "+-----+------+\n",
      "|    0|284315|\n",
      "|    1|283742|\n",
      "+-----+------+\n",
      "\n"
     ]
    },
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "                                                                                \r"
     ]
    }
   ],
   "source": [
    "\n",
    "# 1. Isolate feature columns and vectorize\n",
    "feature_cols = [c for c in df.columns if c != 'Class']\n",
    "assembler = VectorAssembler(inputCols=feature_cols, outputCol=\"features\")\n",
    "df_vec = assembler.transform(df)\n",
    "\n",
    "# 2. Add an ID for the LSH join to avoid matching a point with itself\n",
    "df_vec = df_vec.withColumn(\"id\", monotonically_increasing_id())\n",
    "\n",
    "# 3. Split into majority and minority DataFrames and cache them for speed\n",
    "majority_df = df_vec.filter(col(\"Class\") == 0).cache()\n",
    "minority_df = df_vec.filter(col(\"Class\") == 1).cache()\n",
    "\n",
    "# Calculate exactly how many synthetic samples we need to reach a 50/50 balance\n",
    "maj_count = majority_df.count()\n",
    "min_count = minority_df.count()\n",
    "samples_needed = maj_count - min_count\n",
    "\n",
    "print(\"Finding approximate k-nearest neighbors via LSH...\")\n",
    "brp = BucketedRandomProjectionLSH(\n",
    "    inputCol=\"features\", \n",
    "    outputCol=\"hashes\", \n",
    "    bucketLength=2.0, \n",
    "    numHashTables=3\n",
    ")\n",
    "lsh_model = brp.fit(minority_df)\n",
    "\n",
    "# Join to find neighbors, remove self-matches\n",
    "neighbors = lsh_model.approxSimilarityJoin(\n",
    "    minority_df, \n",
    "    minority_df, \n",
    "    threshold=float('inf'), \n",
    "    distCol=\"EuclideanDistance\"\n",
    ")\n",
    "neighbors = neighbors.filter(col(\"datasetA.id\") != col(\"datasetB.id\"))\n",
    "\n",
    "# Filter to keep only the top k=5 neighbors per minority point\n",
    "windowSpec = Window.partitionBy(\"datasetA.id\").orderBy(\"EuclideanDistance\")\n",
    "top_k_neighbors = neighbors.withColumn(\"rank\", row_number().over(windowSpec)) \\\n",
    "                           .filter(col(\"rank\") <= 5)\n",
    "\n",
    "# Calculate dynamic multiplier: how many points to generate per neighbor pair\n",
    "pair_count = top_k_neighbors.count()\n",
    "multiplier = builtins.max(1, samples_needed // pair_count)\n",
    "\n",
    "print(f\"Generating roughly {samples_needed} synthetic points...\")\n",
    "\n",
    "# Convert PySpark ML Vectors to standard Arrays so PyArrow/Pandas can read them natively\n",
    "prep_df = top_k_neighbors.withColumn(\"base_arr\", vector_to_array(col(\"datasetA.features\"))) \\\n",
    "                         .withColumn(\"neighbor_arr\", vector_to_array(col(\"datasetB.features\")))\n",
    "\n",
    "# Define the Pandas Vectorized UDF\n",
    "# Input: Two Pandas Series (lists of arrays). Output: A Pandas Series (list of lists of arrays)\n",
    "@pandas_udf(ArrayType(ArrayType(DoubleType())))\n",
    "def generate_synthetic_samples_vudf(base_series: pd.Series, neighbor_series: pd.Series) -> pd.Series:\n",
    "    # 1. Convert Series of arrays into highly optimized 2D NumPy Matrices\n",
    "    # Shape: (batch_size, num_features)\n",
    "    base_mat = np.stack(base_series.values) \n",
    "    neigh_mat = np.stack(neighbor_series.values)\n",
    "    \n",
    "    batch_size, num_features = base_mat.shape\n",
    "    \n",
    "    # 2. Vectorized distance calculation\n",
    "    diff_mat = neigh_mat - base_mat\n",
    "    \n",
    "    # 3. Generate random steps for the ENTIRE batch at once\n",
    "    # Shape: (batch_size, multiplier, 1)\n",
    "    random_steps = np.random.uniform(0, 1, size=(batch_size, multiplier, 1))\n",
    "    \n",
    "    # 4. Reshape base matrices to allow 3D broadcasting\n",
    "    # Shape: (batch_size, 1, num_features)\n",
    "    base_expanded = np.expand_dims(base_mat, axis=1)\n",
    "    diff_expanded = np.expand_dims(diff_mat, axis=1)\n",
    "    \n",
    "    # 5. Core SMOTE Equation (Vectorized for millions of points at once)\n",
    "    # Shape: (batch_size, multiplier, num_features)\n",
    "    synthetic_mat = base_expanded + (random_steps * diff_expanded)\n",
    "    \n",
    "    # 6. Convert the 3D NumPy array back to a nested Python list for PySpark\n",
    "    return pd.Series(synthetic_mat.tolist())\n",
    "\n",
    "# Apply the Pandas UDF\n",
    "synthetic_data = prep_df.withColumn(\n",
    "    \"synthetic_arrays\", \n",
    "    generate_synthetic_samples_vudf(col(\"base_arr\"), col(\"neighbor_arr\"))\n",
    ")\n",
    "# 1. Flatten the arrays so every generated point gets its own row\n",
    "# 2. Convert standard arrays back into PySpark ML Vectors\n",
    "# 3. Hardcode the target variable to 1 (Fraud)\n",
    "synthetic_df = synthetic_data.select(\n",
    "    explode(col(\"synthetic_arrays\")).alias(\"synthetic_arr\")\n",
    ").withColumn(\n",
    "    \"features\", array_to_vector(col(\"synthetic_arr\"))\n",
    ").withColumn(\n",
    "    \"Class\", lit(1)\n",
    ").select(\"features\", \"Class\")\n",
    "\n",
    "# Final Standardization and Union\n",
    "minority_clean = minority_df.select(\"features\", \"Class\")\n",
    "majority_clean = majority_df.select(\"features\", \"Class\")\n",
    "\n",
    "final_balanced_df = majority_clean.union(minority_clean).union(synthetic_df)\n",
    "\n",
    "# Display final result\n",
    "print(\"Final Balanced Dataset Distribution:\")\n",
    "final_balanced_df.groupBy(\"Class\").count().show()"
   ]
  },
