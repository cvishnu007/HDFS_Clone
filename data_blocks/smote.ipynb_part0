  {
   "cell_type": "markdown",
   "id": "f10001ab",
   "metadata": {},
   "source": [
    "# CLASS WEIGHTHING METHODS"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "4e435992",
   "metadata": {},
   "source": [
    "**This is Not Exactly OverSampling method but it is used to train datasets that has class imbalance by introducing a class weight which penalises the miscalssification of the minority point**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 71,
   "id": "db661176",
   "metadata": {},
   "outputs": [
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "                                                                                \r"
     ]
    }
   ],
   "source": [
    "# 1. Get the counts of both classes\n",
    "maj_count = df.filter(col(\"Class\") == 0).count()\n",
    "min_count = df.filter(col(\"Class\") == 1).count()\n",
    "\n",
    "# 2. Calculate the balancing ratio\n",
    "# In this dataset, it will be roughly 284315 / 492 ≈ 577\n",
    "balancing_ratio = maj_count / min_count\n",
    "\n",
    "# 3. Create a 'weight' column\n",
    "# Normal transactions get a weight of 1.0. Fraud gets a weight of ~577.0.\n",
    "weighted_df = df.withColumn(\n",
    "    \"class_weight\", \n",
    "    when(col(\"Class\") == 1, balancing_ratio).otherwise(1.0)\n",
    ")\n",
    "\n",
    "# You can now pass this column directly into Spark ML algorithms:\n",
    "# rf = RandomForestClassifier(featuresCol=\"features\", labelCol=\"Class\", weightCol=\"class_weight\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "56bea8f7",
   "metadata": {},
   "source": [
    "# RANDOM OVERSAMPLING"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 72,
   "id": "7b58160f",
   "metadata": {},
   "outputs": [
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "[Stage 624:============================>                            (4 + 4) / 8]\r"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "+-----+------+\n",
      "|Class| count|\n",
      "+-----+------+\n",
      "|    0|284315|\n",
      "|    1|283884|\n",
      "+-----+------+\n",
      "\n"
     ]
    },
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "                                                                                \r"
     ]
    }
   ],
   "source": [
    "\n",
    "# 1. Split the data\n",
    "majority_df = df.filter(col(\"Class\") == 0)\n",
    "minority_df = df.filter(col(\"Class\") == 1)\n",
    "\n",
    "# 2. Calculate how many times we need to duplicate the minority class\n",
    "maj_count = majority_df.count()\n",
    "min_count = minority_df.count()\n",
    "multiplier = int(maj_count / min_count)\n",
    "\n",
    "# 3. Create an array of size 'multiplier', then explode it\n",
    "# This efficiently duplicates every minority row 'multiplier' times natively in Spark\n",
    "duplicated_minority_df = minority_df.withColumn(\n",
    "    \"dummy_array\", \n",
    "    array([lit(1)] * multiplier)\n",
    ").select(\n",
    "    \"*\", \n",
    "    explode(\"dummy_array\")\n",
    ").drop(\"dummy_array\", \"col\") # Drop the dummy columns created by explode\n",
    "\n",
    "# 4. Recombine with the majority class\n",
    "random_oversampled_df = majority_df.union(duplicated_minority_df)\n",
    "\n",
    "random_oversampled_df.groupBy(\"Class\").count().show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 73,
   "id": "b1e49791",
   "metadata": {},
   "outputs": [
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "                                                                                \r"
     ]
    }
   ],
   "source": [
    "random_oversampled_df.coalesce(1).write.csv(\"random-oversampling.csv\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "4a28b9cf",
   "metadata": {},
   "source": [
    "# BORDERLINE SMOTE "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 74,
   "id": "317f7e3e",
   "metadata": {},
   "outputs": [
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "26/06/18 11:28:23 WARN CacheManager: Asked to cache already cached data.\n",
      "26/06/18 11:28:23 WARN CacheManager: Asked to cache already cached data.\n",
      "                                                                                \r"
     ]
    }
   ],
   "source": [
    "\n",
    "# --- 1. SETUP & CROSS-CLASS LSH ---\n",
    "minority_df = df_vec.filter(col(\"Class\") == 1).cache()\n",
    "majority_df = df_vec.filter(col(\"Class\") == 0).cache()\n",
    "all_df = df_vec.cache()\n",
    "\n",
    "samples_needed = majority_df.count() - minority_df.count()\n",
    "\n",
    "# Fit LSH on the ENTIRE dataset to find cross-class neighbors\n",
    "brp_all = BucketedRandomProjectionLSH(inputCol=\"features\", outputCol=\"hashes\", bucketLength=2.0, numHashTables=3)\n",
    "lsh_all = brp_all.fit(all_df)\n",
    "\n",
    "# Join Minority against All Data\n",
    "cross_neighbors = lsh_all.approxSimilarityJoin(minority_df, all_df, float('inf'), \"distance\") \\\n",
    "                         .filter(col(\"datasetA.id\") != col(\"datasetB.id\"))\n",
    "\n",
    "# Get top 5 neighbors for every minority point\n",
    "window_cross = Window.partitionBy(\"datasetA.id\").orderBy(\"distance\")\n",
    "top_5_cross = cross_neighbors.withColumn(\"rank\", row_number().over(window_cross)).filter(col(\"rank\") <= 5)\n",
    "\n",
    "# --- 2. IDENTIFY \"DANGER\" POINTS ---\n",
    "# Count how many of the 5 neighbors belong to the majority class (Class == 0)\n",
    "danger_stats = top_5_cross.groupBy(\"datasetA.id\") \\\n",
    "    .agg(sum((col(\"datasetB.Class\") == 0).cast(\"int\")).alias(\"majority_neighbors\"))\n",
    "\n",
    "# Keep only points with 2, 3, or 4 majority neighbors (The Borderline)\n",
    "danger_ids = danger_stats.filter((col(\"majority_neighbors\") >= 2) & (col(\"majority_neighbors\") <= 4)).select(\"id\")\n",
    "danger_df = minority_df.join(danger_ids, on=\"id\", how=\"inner\")\n",
    "\n",
    "# --- 3. MINORITY LSH (FOR SYNTHESIS) ---\n",
    "brp_min = BucketedRandomProjectionLSH(inputCol=\"features\", outputCol=\"hashes\", bucketLength=2.0, numHashTables=3)\n",
    "lsh_min = brp_min.fit(minority_df)\n",
    "\n",
    "# Join Danger points against Minority points\n",
    "synthesis_pairs = lsh_min.approxSimilarityJoin(danger_df, minority_df, float('inf'), \"distance\") \\\n",
    "                         .filter(col(\"datasetA.id\") != col(\"datasetB.id\"))\n",
    "\n",
    "window_syn = Window.partitionBy(\"datasetA.id\").orderBy(\"distance\")\n",
    "top_5_syn = synthesis_pairs.withColumn(\"rank\", row_number().over(window_syn)).filter(col(\"rank\") <= 5)\n",
    "\n",
    "# Calculate multiplier based on how many danger pairs we found\n",
    "pair_count = top_5_syn.count()\n",
    "multiplier = builtins.max(1, samples_needed // pair_count)\n",
    "\n",
    "# --- 4. PANDAS VECTORIZED UDF ---\n",
    "prep_df = top_5_syn.withColumn(\"base_arr\", vector_to_array(col(\"datasetA.features\"))) \\\n",
    "                   .withColumn(\"neighbor_arr\", vector_to_array(col(\"datasetB.features\")))\n",
    "\n",
    "@pandas_udf(ArrayType(ArrayType(DoubleType())))\n",
    "def borderline_smote_vudf(base_series: pd.Series, neighbor_series: pd.Series) -> pd.Series:\n",
    "    base_mat = np.stack(base_series.values)\n",
    "    neigh_mat = np.stack(neighbor_series.values)\n",
    "    diff_mat = neigh_mat - base_mat\n",
    "    \n",
    "    random_steps = np.random.uniform(0, 1, size=(base_mat.shape[0], multiplier, 1))\n",
    "    base_expanded = np.expand_dims(base_mat, axis=1)\n",
    "    diff_expanded = np.expand_dims(diff_mat, axis=1)\n",
    "    \n",
    "    synthetic_mat = base_expanded + (random_steps * diff_expanded)\n",
    "    return pd.Series(synthetic_mat.tolist())\n",
    "\n",
    "synthetic_data = prep_df.withColumn(\"syn_arrays\", borderline_smote_vudf(col(\"base_arr\"), col(\"neighbor_arr\")))\n",
    "\n",
    "# --- 5. FINALIZE ---\n",
    "synthetic_df = synthetic_data.select(explode(\"syn_arrays\").alias(\"arr\")) \\\n",
    "                             .withColumn(\"features\", array_to_vector(\"arr\")) \\\n",
    "                             .withColumn(\"Class\", lit(1)).select(\"features\", \"Class\")\n",
    "\n",
    "final_borderline_df = majority_df.select(\"features\", \"Class\") \\\n",
    "    .union(minority_df.select(\"features\", \"Class\")) \\\n",
    "    .union(synthetic_df)\n",
    "\n"
   ]
  },
