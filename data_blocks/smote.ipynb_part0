  {
   "cell_type": "markdown",
   "id": "39ac6436",
   "metadata": {},
   "source": [
    "# ADASYN "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 80,
   "id": "c34da06f",
   "metadata": {},
   "outputs": [
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "26/06/18 11:30:33 WARN CacheManager: Asked to cache already cached data.\n",
      "26/06/18 11:30:33 WARN CacheManager: Asked to cache already cached data.\n",
      "26/06/18 11:30:33 WARN CacheManager: Asked to cache already cached data.\n",
      "                                                                                \r"
     ]
    }
   ],
   "source": [
    "\n",
    "# --- 1. SETUP & CROSS-CLASS LSH ---\n",
    "minority_df = df_vec.filter(col(\"Class\") == 1).cache()\n",
    "majority_df = df_vec.filter(col(\"Class\") == 0).cache()\n",
    "all_df = df_vec.cache()\n",
    "\n",
    "samples_needed = majority_df.count() - minority_df.count()\n",
    "\n",
    "# Fit LSH on the ENTIRE dataset\n",
    "brp_all = BucketedRandomProjectionLSH(inputCol=\"features\", outputCol=\"hashes\", bucketLength=2.0, numHashTables=3)\n",
    "lsh_all = brp_all.fit(all_df)\n",
    "\n",
    "cross_neighbors = lsh_all.approxSimilarityJoin(minority_df, all_df, float('inf'), \"distance\") \\\n",
    "                         .filter(col(\"datasetA.id\") != col(\"datasetB.id\"))\n",
    "\n",
    "window_cross = Window.partitionBy(\"datasetA.id\").orderBy(\"distance\")\n",
    "top_5_cross = cross_neighbors.withColumn(\"rank\", row_number().over(window_cross)).filter(col(\"rank\") <= 5)\n",
    "\n",
    "# --- 2. CALCULATE ADASYN WEIGHTS (g_i) ---\n",
    "# Calculate r_i: ratio of majority neighbors\n",
    "density_stats = top_5_cross.groupBy(\"datasetA.id\") \\\n",
    "    .agg((sum((col(\"datasetB.Class\") == 0).cast(\"double\")) / 5.0).alias(\"r_i\"))\n",
    "\n",
    "# Normalize r_i so they sum to 1\n",
    "sum_r = density_stats.select(sum(\"r_i\")).collect()[0][0]\n",
    "density_stats = density_stats.withColumn(\"r_hat\", col(\"r_i\") / sum_r)\n",
    "\n",
    "# Calculate g_i: exact number of synthetic samples to generate for this specific point\n",
    "density_stats = density_stats.withColumn(\"g_i\", round(col(\"r_hat\") * samples_needed).cast(\"int\"))\n",
    "\n",
    "# Attach g_i back to the minority points\n",
    "adasyn_df = minority_df.join(density_stats.select(\"id\", \"g_i\"), on=\"id\", how=\"inner\").filter(col(\"g_i\") > 0)\n",
    "\n",
    "# --- 3. MINORITY LSH (FOR SYNTHESIS) ---\n",
    "brp_min = BucketedRandomProjectionLSH(inputCol=\"features\", outputCol=\"hashes\", bucketLength=2.0, numHashTables=3)\n",
    "lsh_min = brp_min.fit(minority_df)\n",
    "\n",
    "synthesis_pairs = lsh_min.approxSimilarityJoin(adasyn_df, minority_df, float('inf'), \"distance\") \\\n",
    "                         .filter(col(\"datasetA.id\") != col(\"datasetB.id\"))\n",
    "\n",
    "# Just grab 1 random neighbor for each point to interpolate with\n",
    "window_syn = Window.partitionBy(\"datasetA.id\").orderBy(\"distance\")\n",
    "top_1_syn = synthesis_pairs.withColumn(\"rank\", row_number().over(window_syn)).filter(col(\"rank\") == 1)\n",
    "\n",
    "# --- 4. DYNAMIC PANDAS VECTORIZED UDF ---\n",
    "prep_df = top_1_syn.withColumn(\"base_arr\", vector_to_array(col(\"datasetA.features\"))) \\\n",
    "                   .withColumn(\"neighbor_arr\", vector_to_array(col(\"datasetB.features\"))) \\\n",
    "                   .withColumn(\"g_i\", col(\"datasetA.g_i\")) # Bring the dynamic count into the UDF\n",
    "\n",
    "@pandas_udf(ArrayType(ArrayType(DoubleType())))\n",
    "def adasyn_vudf(base_series: pd.Series, neighbor_series: pd.Series, g_series: pd.Series) -> pd.Series:\n",
    "    base_mat = np.stack(base_series.values)\n",
    "    neigh_mat = np.stack(neighbor_series.values)\n",
    "    g_counts = g_series.values\n",
    "    \n",
    "    diff_mat = neigh_mat - base_mat\n",
    "    \n",
    "    # Use np.repeat to duplicate the rows based on their specific g_i value\n",
    "    # If row 1 needs 50 points and row 2 needs 10, it creates a matrix of size 60\n",
    "    base_rep = np.repeat(base_mat, g_counts, axis=0)\n",
    "    diff_rep = np.repeat(diff_mat, g_counts, axis=0)\n",
    "    \n",
    "    # Generate random steps for the exact number of duplicated rows\n",
    "    random_steps = np.random.uniform(0, 1, size=(base_rep.shape[0], 1))\n",
    "    \n",
    "    synthetic_flat = base_rep + (random_steps * diff_rep)\n",
    "    \n",
    "    # Re-pack the flat array back into the original row groupings for PySpark\n",
    "    result = []\n",
    "    current_idx = 0\n",
    "    for count in g_counts:\n",
    "        result.append(synthetic_flat[current_idx : current_idx + count].tolist())\n",
    "        current_idx += count\n",
    "        \n",
    "    return pd.Series(result)\n",
    "\n",
    "synthetic_data = prep_df.withColumn(\"syn_arrays\", adasyn_vudf(col(\"base_arr\"), col(\"neighbor_arr\"), col(\"g_i\")))\n",
    "\n",
    "# --- 5. FINALIZE ---\n",
    "synthetic_df = synthetic_data.select(explode(\"syn_arrays\").alias(\"arr\")) \\\n",
    "                             .withColumn(\"features\", array_to_vector(\"arr\")) \\\n",
    "                             .withColumn(\"Class\", lit(1)).select(\"features\", \"Class\")\n",
    "\n",
    "final_adasyn_df = majority_df.select(\"features\", \"Class\") \\\n",
    "    .union(minority_df.select(\"features\", \"Class\")) \\\n",
    "    .union(synthetic_df)"
   ]
  },
