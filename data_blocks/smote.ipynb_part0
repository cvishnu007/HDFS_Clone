     "output_type": "stream",
     "text": [
      "+-----+------+\n",
      "|Class| count|\n",
      "+-----+------+\n",
      "|    0|284315|\n",
      "|    1|  1625|\n",
      "+-----+------+\n",
      "\n"
     ]
    },
    {
     "name": "stderr",
